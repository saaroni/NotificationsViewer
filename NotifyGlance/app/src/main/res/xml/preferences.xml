<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ── When to Display ───────────────────────────────── -->
    <PreferenceCategory android:title="When to Display">

        <CheckBoxPreference
            android:key="pref_trigger_on_new"
            android:title="Trigger on New Notifications"
            android:summary="Show overlay immediately when a new notification arrives"
            android:defaultValue="true" />

        <ListPreference
            android:key="pref_timed_session"
            android:title="Timed Sessions"
            android:summary="%s"
            android:entries="@array/timed_session_labels"
            android:entryValues="@array/timed_session_values"
            android:defaultValue="off" />

    </PreferenceCategory>

    <!-- ── Session Length ────────────────────────────────── -->
    <PreferenceCategory android:title="Session Length">

        <ListPreference
            android:key="pref_max_cards"
            android:title="Max Cards Per Session"
            android:summary="%s cards"
            android:entries="@array/max_cards_labels"
            android:entryValues="@array/max_cards_values"
            android:defaultValue="5" />

        <ListPreference
            android:key="pref_card_display_sec"
            android:title="Per-Card Display Time"
            android:summary="%s seconds per card"
            android:entries="@array/card_sec_labels"
            android:entryValues="@array/card_sec_values"
            android:defaultValue="5" />

        <EditTextPreference
            android:key="pref_overlay_lookback_minutes"
            android:title="Show Notifications From Last (minutes)"
            android:summary="Enter a value between 15 and 360"
            android:defaultValue="60"
            android:inputType="number" />


    </PreferenceCategory>

    <!-- ── Quiet Hours ───────────────────────────────────── -->
    <PreferenceCategory android:title="Quiet Hours">

        <EditTextPreference
            android:key="pref_quiet_start"
            android:title="Quiet Hours Start"
            android:summary="Format: HH:mm (e.g. 22:00)"
            android:defaultValue="" />

        <EditTextPreference
            android:key="pref_quiet_end"
            android:title="Quiet Hours End"
            android:summary="Format: HH:mm (e.g. 07:00)"
            android:defaultValue="" />

    </PreferenceCategory>

    <!-- ── Filters ───────────────────────────────────────── -->
    <PreferenceCategory android:title="Notification Filters">

        <Preference
            android:key="pref_allowed_apps"
            android:title="Allowed Apps"
            android:summary="@string/allowed_apps_summary_default" />

        <CheckBoxPreference
            android:key="pref_suppress_ongoing"
            android:title="Suppress Ongoing / System Notifications"
            android:summary="Hide media players, downloads, and foreground service spam"
            android:defaultValue="true" />

    </PreferenceCategory>

    <!-- ── Appearance ────────────────────────────────────── -->
    <PreferenceCategory android:title="Appearance">

        <ListPreference
            android:key="pref_font_size"
            android:title="Font Size"
            android:summary="%s"
            android:entries="@array/font_size_labels"
            android:entryValues="@array/font_size_values"
            android:defaultValue="xl" />

        <CheckBoxPreference
            android:key="pref_high_contrast"
            android:title="High-Contrast Theme"
            android:summary="Black background with white text"
            android:defaultValue="false" />

    </PreferenceCategory>

    <!-- ── Diagnostics ───────────────────────────────────── -->
    <PreferenceCategory android:title="About / Diagnostics">

        <Preference
            android:key="pref_diagnostics_screen"
            android:title="Open Diagnostics"
            android:summary="Service status, last overlay time, and test tools" />

    </PreferenceCategory>

</PreferenceScreen>
